{
  "rooms": {
    "entrance_complex": {
      "id": "entrance_complex",
      "name": {
        "chinese": "入口 Complex",
        "pinyin": "Rùkǒu Complex",
        "english": "Entrance Complex"
      },
      "description": {
        "chinese": "错综复杂的入口通道网络展现在你面前。石壁上刻着古老的符文，微弱的光芒从裂缝中透出。",
        "pinyin": "Cuòzōng fùzá de rùkǒu tōngdào wǎngluò zhǎnxiàn zài nǐ miànqián. Shíbì shàng kèzhe gǔlǎo de fúwén, wēiruò de guāngmáng cóng lièfèng zhōng tòu chū.",
        "english": "A complex network of entrance passages spreads before you. Ancient runes are carved into the stone walls, and faint light filters through cracks."
      }
    },
    "storage_area": {
      "id": "storage_area",
      "name": {
        "chinese": "储藏区",
        "pinyin": "Chǔcáng Qū",
        "english": "Storage Area"
      },
      "description": {
        "chinese": "一个用于存放物资的区域。货架上堆满了各种容器，空气中弥漫着灰尘和霉味。",
        "pinyin": "Yī gè yòng yú cúnfàng wùzī de qūyù. Huòjià shàng duī mǎnle gè zhǒng róngqì, kōngqì zhōng mí màn zhe huīchén hé méi wèi.",
        "english": "An area used for storing supplies. Shelves are stacked with various containers, and the air is thick with dust and mustiness."
      }
    },
    "armory_complex": {
      "id": "armory_complex",
      "name": {
        "chinese": "军械库 Complex",
        "pinyin": "Jūnxièkù Complex",
        "english": "Armory Complex"
      },
      "description": {
        "chinese": "广阔的军械库网络，墙上挂满了武器和盔甲。锻造炉的余温仍然可以感受到。",
        "pinyin": "Guǎngkuò de jūnxièkù wǎngluò, qiáng shàng guà mǎnle wǔqì hé kuījiǎ. Duànzào lú de yú wēn réngrán kěyǐ gǎnshòu dào.",
        "english": "A vast armory network, with weapons and armor hanging on the walls. The residual heat of the forge can still be felt."
      }
    },
    "hallway_b_complex": {
      "id": "hallway_b_complex",
      "name": {
        "chinese": "走廊B Complex",
        "pinyin": "Zǒuláng B Complex",
        "english": "Hallway B Complex"
      },
      "description": {
        "chinese": "一条漫长的走廊，墙壁上装饰着褪色的壁画。脚步声在空旷的通道中回荡。",
        "pinyin": "Yī tiáo màncháng de zǒuláng, qiángbì shàng zhuāngshì zhe tuìsè de bìhuà. Jiǎobù shēng zài kōngkuàng de tōngdào zhōng huídàng.",
        "english": "A long hallway adorned with faded murals. Footsteps echo through the empty passages."
      }
    },
    "anteroom_complex": {
      "id": "anteroom_complex",
      "name": {
        "chinese": "前厅 Complex",
        "pinyin": "Qiántīng Complex",
        "english": "Anteroom Complex"
      },
      "description": {
        "chinese": "一个复杂的前厅网络，连接着多个区域。华丽的石柱支撑着高高的天花板。",
        "pinyin": "Yī gè fùzá de qiántīng wǎngluò, liánjiē zhe duō gè qūyù. Huálì de shízhù zhīchēng zhe gāogāo de tiānhuābǎn.",
        "english": "A complex network of anterooms connecting multiple areas. Ornate stone pillars support the high ceiling."
      }
    },
    "hallway_c_complex": {
      "id": "hallway_c_complex",
      "name": {
        "chinese": "走廊C Complex",
        "pinyin": "Zǒuláng C Complex",
        "english": "Hallway C Complex"
      },
      "description": {
        "chinese": "一条通向王座室的走廊。空气变得更加沉重，远处隐约传来王座室的光芒。",
        "pinyin": "Yī tiáo tōng xiàng wángzuò shì de zǒuláng. Kōngqì biàn de gèngjiā chénzhòng, yuǎn chù yǐnyuē chuán lái wángzuò shì de guāngmáng.",
        "english": "A hallway leading to the throne room. The air grows heavier, and the glow of the throne room can be faintly seen in the distance."
      }
    },
    "throne_complex": {
      "id": "throne_complex",
      "name": {
        "chinese": "王座 Complex",
        "pinyin": "Wángzuò Complex",
        "english": "Throne Complex"
      },
      "description": {
        "chinese": "宏伟的王座 Complex 展现在你面前。高耸的石柱支撑着拱形天花板，墙上挂着古老的挂毯。空气中弥漫着权力和历史的厚重感。",
        "pinyin": "Hóngwěi de wángzuò complex zhǎnxiàn zài nǐ miànqián. Gāosǒng de shízhù zhīchēng zhe gǒngxíng tiānhuābǎn, qiáng shàng guà zhe gǔlǎo de guàtǎn. Kōngqì zhōng mí màn zhe quánlì hé lìshǐ de hòuzhòng gǎn.",
        "english": "The magnificent Throne Complex spreads before you. Towering stone pillars support arched ceilings, and ancient tapestries hang from the walls. The air is thick with the weight of power and history."
      }
    }
  },
