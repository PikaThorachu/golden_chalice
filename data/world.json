{
  "rooms": {
    "entrance_chamber": {
      "id": "entrance_chamber",
      "name": {
        "chinese": "入口厅",
        "pinyin": "Rùkǒu Tīng",
        "english": "Entrance Chamber"
      },
      "description": {
        "chinese": "一条狭窄的入口通道呈现在你眼前。石壁上刻着古老的符文，微弱的光线透过缝隙透射进来。入口厅的后方设有出口，或许值得前去一探究竟。",
        "pinyin": "Yītiáo xiázhǎi de rùkǒu tōngdào chéngxiàn zài nǐ yǎnqián. Shíbì shàng kèzhe gǔlǎo de fú wén, wéiruò de guāngxiàn tòuguò fèngxì tòushè jìnlái. Rùkǒu tīng de hòufāng shè yǒu chūkǒu, huòxǔ zhídé qián qù yī tàn jiùjìng.",
        "english": "A small entrance passage opens before you. Ancient runes are carved into the stone walls, and faint light filters through cracks. There are exits at the back of the entrance chamber that may be worth exploring."
      }
    },
    "store_room": {
      "id": "store_room",
      "name": {
        "chinese": "储藏室",
        "pinyin": "Chǔcáng Shì",
        "english": "Store Room"
      },
      "description": {
        "chinese": "一个用于存放物资的区域。货架上堆满了各种容器，空气中弥漫着灰尘和霉味。",
        "pinyin": "Yī gè yòng yú cúnfàng wùzī de qūyù. Huòjià shàng duī mǎnle gè zhǒng róngqì, kōngqì zhōng mí màn zhe huīchén hé méi wèi.",
        "english": "An area used for storing supplies. Shelves are stacked with various containers, and the air is thick with dust and mustiness."
      }
    },
    "armory": {
      "id": "armory",
      "name": {
        "chinese": "军械库",
        "pinyin": "Jūnxièkù",
        "english": "Armory"
      },
      "description": {
        "chinese": "这是一间小型军械库，墙上悬挂着古老的武器与盔甲。四处皆布满尘埃与蛛网。显然，这间屋子已许久未曾使用。",
        "pinyin": "Zhè shì yī jiàn xiǎoxíng jūnxiè kù, qiáng shàng xuánguàzhe gǔlǎo de wǔqì yǔ kuījiǎ. Sìchù jiē bù mǎn chén'āi yǔ zhūwǎng. Xiǎnrán, zhè jiān wūzǐ yǐ xǔjiǔ wèicéng shǐyòng.",
        "english": "A small armory with ancient weapons and armor hanging on the walls. There is dust and spiderwebs hanging every. This room has clearly not been used in a long time."
      }
    },
    "anteroom": {
      "id": "anteroom",
      "name": {
        "chinese": "前厅",
        "pinyin": "Qiántīng",
        "english": "Anteroom"
      },
      "description": {
        "chinese": "一间狭小的房间，一张破旧的办公桌正对着一张破损不堪的沙发。墙上歪斜地挂着几幅褪了色的画作，画中人物皆是早已作古的统治者。",
        "pinyin": "Yī jiàn xiáxiǎo de fángjiān, yī zhāng pòjiù de bàngōng zhuō zhèng duìzhe yī zhāng pòsǔn bùkān dì shāfā. Qiáng shàng wāixié dì guàzhe jǐ fú tuìle sè de huàzuò, huà zhōng rénwù jiē shì zǎoyǐ zuògǔ de tǒngzhì zhě.",
        "english": "A small room with a broken old desk across from a broken, tattered couch. Faded paintings of long-dead rulers hang askew on the walls."
      }
    },
    "throne_room": {
      "id": "throne_room",
      "name": {
        "chinese": "王座室",
        "pinyin": "Wángzuò shì",
        "english": "Throne Room"
      },
      "description": {
        "chinese": "一间宽敞的大厅在你的眼前铺展开来。环顾四周，随处可见精巧繁复的装饰、陈列着的武器与盔甲，以及摆放着珠宝的展示柜。大厅深处，一座雕工精美的王座端坐于高台之上。空气中弥漫着一种厚重的力量感与历史气息。",
        "pinyin": "Yī jiàn kuānchǎng de dàtīng zài nǐ de yǎnqián pūzhǎn kāi lái. Huángù sìzhōu, suíchù kějiàn jīngqiǎo fánfù de zhuāngshì, chénlièzhe de wǔqì yǔ kuījiǎ, yǐjí bǎi fàngzhe zhūbǎo de zhǎnshì guì. Dàtīng shēn chù, yīzuò diāo gōng jīngměi de wángzuò duān zuò yú gāotái zhī shàng. Kōngqì zhòng mímànzhe yī zhǒng hòuzhòng de lìliàng gǎn yǔ lìshǐ qìxí.",
        "english": "A large room spreads out before you. All around the room, you can see elaborate decorations, weapons and armor displays, display cases with jewels. At the back of the room, an elaborate throne sits on a dias. The air is thick with a sense of power and history."
      }
    },
    "hallway_a": {
      "id": "hallway_a",
      "name": {
        "chinese": "走廊A",
        "pinyin": "Zǒuláng A",
        "english": "Hallway A"
      },
      "description": {
        "chinese": "一条漫长的走廊，墙壁上装饰着褪色的壁画。脚步声在空旷的通道中回荡。",
        "pinyin": "Yī tiáo màncháng de zǒuláng, qiángbì shàng zhuāngshì zhe tuìsè de bìhuà. Jiǎobù shēng zài kōngkuàng de tōngdào zhōng huídàng.",
        "english": "A long hallway adorned with faded murals. Footsteps echo through the empty passages."
      }
    },
    "hallway_b": {
      "id": "hallway_b",
      "name": {
        "chinese": "走廊B",
        "pinyin": "Zǒuláng B",
        "english": "Hallway B"
      },
      "description": {
        "chinese": "一条漫长的走廊，墙壁上装饰着褪色的壁画。脚步声在空旷的通道中回荡。",
        "pinyin": "Yī tiáo màncháng de zǒuláng, qiángbì shàng zhuāngshì zhe tuìsè de bìhuà. Jiǎobù shēng zài kōngkuàng de tōngdào zhōng huídàng.",
        "english": "A long hallway adorned with faded murals. Footsteps echo through the empty passages."
      }
    },
    "hallway_c": {
      "id": "hallway_c",
      "name": {
        "chinese": "走廊C",
        "pinyin": "Zǒuláng C",
        "english": "Hallway C"
      },
      "description": {
        "chinese": "一条通向王座室的走廊。空气变得更加沉重，远处隐约传来王座室的光芒。",
        "pinyin": "Yī tiáo tōng xiàng wángzuò shì de zǒuláng. Kōngqì biàn de gèngjiā chénzhòng, yuǎn chù yǐnyuē chuán lái wángzuò shì de guāngmáng.",
        "english": "A hallway leading to the throne room. The air grows heavier, and the glow of the throne room can be faintly seen in the distance."
      }
    }
  },
